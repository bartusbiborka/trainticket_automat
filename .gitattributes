# 1. Force everything to be ignored by default
* linguist-vendored
* linguist-documentation

# 2. Explicitly UN-IGNORE only your VHDL code
*.vhd linguist-vendored=false
*.vhd linguist-language=VHDL

# 3. Explicitly hide Tcl and XML forever
*.tcl linguist-detectable=false
*.xml linguist-detectable=false
**/*.srcs/** linguist-detectable=false