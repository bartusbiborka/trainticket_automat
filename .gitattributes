# 1. Force VHDL as the primary language
*.vhd linguist-language=VHDL

# 2. Treat ALL .tcl files (everywhere) as generated so they are hidden from stats
**/*.tcl linguist-vendor=true
*.tcl linguist-vendor=true

# 3. Mark Vivado-specific project files as generated/documentation
**/*.srcs/** linguist-documentation
**/*.ip_user_files/** linguist-documentation
**/*.xpr linguist-generated
**/*.xml linguist-generated
**/*.jou linguist-generated
**/*.log linguist-generated