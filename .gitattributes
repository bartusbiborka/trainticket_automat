# Force VHDL to be the primary language
*.vhd linguist-language=VHDL

# Treat all Tcl files as 'generated' so they don't count towards statistics
*.tcl linguist-generated
**/*.tcl linguist-generated

# Treat all Vivado project files as documentation/noise
**/*.srcs/** linguist-documentation
**/*.ip_user_files/** linguist-documentation
**/*.xpr linguist-generated
**/*.xml linguist-generated